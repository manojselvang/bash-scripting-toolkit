#!/bin/bash

# Renames .log files and handles other files using else condition

LOG_DIR="/home/user/log_archiver/logs"

# Check if directory exists
if [[ ! -d "$LOG_DIR" ]]; then
    echo "Directory not found: $LOG_DIR"
    exit 1
fi

# Loop through all files
for file in "$LOG_DIR"/*; do

    if [[ -e "$file" ]]; then

        # If file is .log
        if [[ "$file" == *.log ]]; then
            mv "$file" "$file.old"
            echo "Renamed: $file -> $file.old"

        else
            echo "Skipped (not a .log file): $file"
        fi

    fi

done